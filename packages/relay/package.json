{
  "name": "@mulmobridge/relay",
  "version": "0.2.0",
  "description": "Cloudflare Workers relay for MulmoBridge — receives webhooks, queues messages, forwards via WebSocket to MulmoClaude",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./client": "./dist/client.js",
    "./types": "./dist/types.js"
  },
  "files": [
    "dist",
    "src",
    "wrangler.toml",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test test/test_*.ts"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260601.1",
    "typescript": "^6.0.3",
    "wrangler": "^4.93.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "dependencies": {
    "@mulmobridge/client": "^0.1.3"
  }
}
