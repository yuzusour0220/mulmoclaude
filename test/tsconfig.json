{
  // Dedicated type-check config for `test/**`. Adds `test/` to the
  // type-check coverage that was otherwise gated only by ESLint + the
  // runtime tsx loader (which skips type checking entirely).
  //
  // Not used to BUILD the tests — `tsx --test` still runs them. This
  // config exists solely so `yarn typecheck:test` can flag type drift
  // (e.g. a renamed server-side type that test files haven't caught up
  // with) before it reaches CI.
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node"],
    // Tests import Vue composables that touch `.vue` files
    // transitively — skipping lib check is enough to let those
    // references type-check without pulling in the full Vue
    // compiler.
    "jsx": "preserve"
  },
  "include": ["**/*.ts", "../src/**/*.ts", "../server/**/*.ts", "../packages/*/src/**/*.ts"],
  "exclude": [
    "../node_modules",
    "../dist",
    "../packages/relay",
    // Build-time copies generated by prepare-dist.js into the
    // launcher package. They reference packages installed only at
    // launcher install time (e.g. @mulmochat-plugin/form), not in
    // this workspace's node_modules.
    "../packages/mulmoclaude/src",
    "../packages/mulmoclaude/server",
    "../packages/mulmoclaude/client",
    // Fixtures for scripts/mulmoclaude/deps.mjs — deliberately minimal
    // TS files used only as regex inputs. Type-checking them would
    // fail because they reference packages (e.g. `mammoth/lib/foo`)
    // that aren't installed as dev deps at this repo's root.
    "scripts/mulmoclaude/fixtures",
    // Docker-sandbox regression probe. Runs INSIDE a Linux container
    // that bind-mounts `server/plugins/resolvePresetRoot.ts` at
    // `/app/server-plugins/resolvePresetRoot.ts` — a path that
    // doesn't exist on the host, so type-checking it here can't
    // resolve the import. The probe is executed via tsx inside the
    // container by `.github/workflows/docker_sandbox_windows.yaml`;
    // its shape is validated at runtime there.
    "sandbox-repro"
  ]
}
